{
  "run": {
    "description": "",
    "input_schema": {
      "properties": {
        "prompt": {
          "description": "Text prompt describing the desired edit. Use [[profile_id]] to reference trained profiles.",
          "title": "Prompt",
          "type": "string"
        },
        "images": {
          "description": "Input images to edit (1-10). Accepts image files or URLs.",
          "items": {
            "format": "file",
            "type": "string"
          },
          "title": "Images",
          "type": "array"
        },
        "profile_ids": {
          "anyOf": [
            {
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Profile IDs for identity preservation. Only pass profiles relevant to this end-user.",
          "title": "Profile Ids"
        },
        "num_output_images": {
          "default": 1,
          "description": "Number of output images (1-4)",
          "maximum": 4,
          "minimum": 1,
          "title": "Num Output Images",
          "type": "integer"
        },
        "aspect_ratio": {
          "default": "auto",
          "description": "Output aspect ratio",
          "enum": [
            "auto",
            "1:1",
            "3:4",
            "4:3",
            "9:16",
            "16:9"
          ],
          "title": "Aspect Ratio",
          "type": "string"
        },
        "resolution": {
          "default": "1K",
          "description": "Output resolution",
          "enum": [
            "1K",
            "4K"
          ],
          "title": "Resolution",
          "type": "string"
        }
      },
      "required": [
        "prompt",
        "images"
      ],
      "title": "RunInput",
      "type": "object"
    },
    "output_schema": {
      "properties": {
        "images": {
          "description": "Edited output images",
          "items": {
            "format": "file",
            "type": "string"
          },
          "title": "Images",
          "type": "array"
        },
        "known_subjects": {
          "anyOf": [
            {
              "additionalProperties": true,
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Mapping of profile_id to generation count",
          "title": "Known Subjects"
        }
      },
      "required": [
        "images"
      ],
      "title": "RunOutput",
      "type": "object"
    }
  }
}