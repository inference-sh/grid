              "anyOf": [
                {
                  "additionalProperties": true,
                  "type": "object"
                },
                {
                  "type": "null"
                }
              ],
              "default": null,
              "description": "App-specific key-value pairs for custom pricing factors",
              "title": "Extra"
            },
            "tokens": {
              "default": 0,
              "description": "Token count - in inputs[] = input tokens, in outputs[] = output tokens",
