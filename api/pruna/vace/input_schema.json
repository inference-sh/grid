{
  "$defs": {
    "SizeEnum": {
      "enum": [
        "720*1280",
        "1280*720",
        "480*832",
        "832*480"
      ],
      "title": "SizeEnum",
      "type": "string"
    },
    "SolverEnum": {
      "enum": [
        "unipc",
        "dpm++"
      ],
      "title": "SolverEnum",
      "type": "string"
    },
    "SpeedModeEnum": {
      "enum": [
        "Lightly Juiced \ud83c\udf4a (more consistent)",
        "Juiced \ud83d\udd25 (more speed)",
        "Extra Juiced \ud83d\ude80 (even more speed)"
      ],
      "title": "SpeedModeEnum",
      "type": "string"
    }
  },
  "properties": {
    "prompt": {
      "description": "Description of the video content.",
      "title": "Prompt",
      "type": "string"
    },
    "src_video": {
      "anyOf": [
        {
          "format": "file",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Source video to edit/transform.",
      "title": "Src Video"
    },
    "src_mask": {
      "anyOf": [
        {
          "format": "file",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Mask video/image for editing.",
      "title": "Src Mask"
    },
    "src_ref_images": {
      "anyOf": [
        {
          "items": {
            "format": "file",
            "type": "string"
          },
          "type": "array"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Reference images for character consistency (1-3).",
      "title": "Src Ref Images"
    },
    "size": {
      "$ref": "#/$defs/SizeEnum",
      "default": "832*480",
      "description": "Output video resolution."
    },
    "frame_num": {
      "default": 81,
      "description": "Number of frames to generate.",
      "title": "Frame Num",
      "type": "integer"
    },
    "speed_mode": {
      "$ref": "#/$defs/SpeedModeEnum",
      "default": "Lightly Juiced \ud83c\udf4a (more consistent)",
      "description": "Speed vs quality balance."
    },
    "sample_steps": {
      "default": 50,
      "description": "Sampling steps (higher = better quality).",
      "title": "Sample Steps",
      "type": "integer"
    },
    "sample_solver": {
      "$ref": "#/$defs/SolverEnum",
      "default": "unipc",
      "description": "Sampling algorithm."
    },
    "sample_guide_scale": {
      "default": 5.0,
      "description": "How closely to follow the prompt.",
      "title": "Sample Guide Scale",
      "type": "number"
    },
    "sample_shift": {
      "default": 16,
      "description": "Sample shift parameter.",
      "title": "Sample Shift",
      "type": "integer"
    },
    "seed": {
      "default": -1,
      "description": "Random seed (-1 for random).",
      "title": "Seed",
      "type": "integer"
    }
  },
  "required": [
    "prompt"
  ],
  "title": "AppInput",
  "type": "object"
}