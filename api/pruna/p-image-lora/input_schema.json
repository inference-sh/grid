{
  "$defs": {
    "AspectRatioEnum": {
      "enum": [
        "1:1",
        "16:9",
        "9:16",
        "4:3",
        "3:4",
        "3:2",
        "2:3",
        "custom"
      ],
      "title": "AspectRatioEnum",
      "type": "string"
    },
    "LoraPresetEnum": {
      "description": "Pre-trained LoRA styles available on HuggingFace.",
      "enum": [
        "photos-realism",
        "pixel-art",
        "photos-modernism-art",
        "pencil-sketch-art",
        "photos-classic-film",
        "comic-noir-art",
        "classic-painting",
        "photos-sunbleached",
        "photos-three-color-composite",
        "text-rendering",
        "comic-noir-v2"
      ],
      "title": "LoraPresetEnum",
      "type": "string"
    }
  },
  "description": "Input schema for P-Image-LoRA.",
  "properties": {
    "prompt": {
      "description": "Text description of the image to generate.",
      "title": "Prompt",
      "type": "string"
    },
    "lora_preset": {
      "$ref": "#/$defs/LoraPresetEnum",
      "default": "photos-realism",
      "description": "Pre-trained LoRA style."
    },
    "lora_url": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Custom LoRA URL (overrides preset). Format: huggingface.co/owner/repo/file.safetensors",
      "title": "Lora Url"
    },
    "lora_scale": {
      "default": 0.5,
      "description": "LoRA strength (-1 to 3). 0.5 works well for most.",
      "maximum": 3,
      "minimum": -1,
      "title": "Lora Scale",
      "type": "number"
    },
    "hf_api_token": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "HuggingFace API token for private LoRAs.",
      "title": "Hf Api Token"
    },
    "aspect_ratio": {
      "$ref": "#/$defs/AspectRatioEnum",
      "default": "16:9",
      "description": "Aspect ratio for the image."
    },
    "width": {
      "anyOf": [
        {
          "maximum": 1440,
          "minimum": 256,
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Custom width in pixels (256-1440, multiple of 16). Only used when aspect_ratio=custom.",
      "title": "Width"
    },
    "height": {
      "anyOf": [
        {
          "maximum": 1440,
          "minimum": 256,
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Custom height in pixels (256-1440, multiple of 16). Only used when aspect_ratio=custom.",
      "title": "Height"
    },
    "prompt_upsampling": {
      "default": false,
      "description": "Enhance prompt with LLM for better results.",
      "title": "Prompt Upsampling",
      "type": "boolean"
    },
    "seed": {
      "anyOf": [
        {
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Random seed for reproducible generation.",
      "title": "Seed"
    },
    "disable_safety_checker": {
      "default": false,
      "description": "Disable safety checker for generated images.",
      "title": "Disable Safety Checker",
      "type": "boolean"
    }
  },
  "required": [
    "prompt"
  ],
  "title": "AppInput",
  "type": "object"
}