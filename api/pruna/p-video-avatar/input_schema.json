{
  "$defs": {
    "ResolutionEnum": {
      "enum": [
        "720p",
        "1080p"
      ],
      "title": "ResolutionEnum",
      "type": "string"
    },
    "VoiceEnum": {
      "enum": [
        "Zephyr (Female)",
        "Puck (Male)",
        "Charon (Male)",
        "Kore (Female)",
        "Fenrir (Male)",
        "Leda (Female)",
        "Orus (Male)",
        "Aoede (Female)",
        "Callirrhoe (Female)",
        "Autonoe (Female)",
        "Enceladus (Male)",
        "Iapetus (Male)",
        "Umbriel (Male)",
        "Algenib (Male)",
        "Despina (Female)",
        "Erinome (Female)",
        "Laomedeia (Female)",
        "Achernar (Female)",
        "Algieba (Male)",
        "Schedar (Male)",
        "Gacrux (Female)",
        "Pulcherrima (Female)",
        "Achird (Male)",
        "Zubenelgenubi (Male)",
        "Vindemiatrix (Female)",
        "Sadachbia (Male)",
        "Sadaltager (Male)",
        "Sulafat (Female)",
        "Alnilam (Male)",
        "Rasalgethi (Male)"
      ],
      "title": "VoiceEnum",
      "type": "string"
    },
    "VoiceLanguageEnum": {
      "enum": [
        "English (US)",
        "English (UK)",
        "Spanish",
        "French",
        "German",
        "Italian",
        "Portuguese (Brazil)",
        "Japanese",
        "Korean",
        "Hindi"
      ],
      "title": "VoiceLanguageEnum",
      "type": "string"
    }
  },
  "anyOf": [
    {
      "properties": {
        "voice_script": {
          "not": {
            "type": "null"
          }
        }
      }
    },
    {
      "properties": {
        "audio": {
          "not": {
            "type": "null"
          }
        }
      }
    }
  ],
  "description": "Input schema for P-Video-Avatar.",
  "properties": {
    "image": {
      "description": "Portrait image (first frame). Supports jpg, jpeg, png, webp.",
      "format": "file",
      "title": "Image",
      "type": "string"
    },
    "voice_script": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Script for the person to say. Required if no audio provided.",
      "title": "Voice Script",
      "x-promoted": true
    },
    "audio": {
      "anyOf": [
        {
          "format": "file",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Audio file to drive speech. If both audio and voice_script are provided, audio is used.",
      "title": "Audio",
      "x-promoted": true
    },
    "voice": {
      "$ref": "#/$defs/VoiceEnum",
      "default": "Zephyr (Female)",
      "description": "Voice for generated speech (used with voice_script)."
    },
    "voice_language": {
      "$ref": "#/$defs/VoiceLanguageEnum",
      "default": "English (US)",
      "description": "Output language for generated speech."
    },
    "resolution": {
      "$ref": "#/$defs/ResolutionEnum",
      "default": "720p",
      "description": "Video resolution: 720p or 1080p."
    },
    "video_prompt": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Optional prompt for the video (default: 'The person is talking.').",
      "title": "Video Prompt"
    },
    "voice_prompt": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Optional speaking style, tone, pacing or emotion instructions.",
      "title": "Voice Prompt"
    },
    "seed": {
      "anyOf": [
        {
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Random seed for reproducible generation.",
      "title": "Seed"
    },
    "disable_safety_filter": {
      "default": true,
      "description": "Disable safety filter for prompts and input image.",
      "title": "Disable Safety Filter",
      "type": "boolean"
    },
    "disable_prompt_upsampling": {
      "default": false,
      "description": "Skip the multimodal prompt upsampler and use raw prompt.",
      "title": "Disable Prompt Upsampling",
      "type": "boolean"
    }
  },
  "required": [
    "image"
  ],
  "title": "AppInput",
  "type": "object"
}