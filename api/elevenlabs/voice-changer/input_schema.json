{
  "description": "Input schema for ElevenLabs Voice Changer.",
  "properties": {
    "audio": {
      "description": "Input audio file containing speech to transform.",
      "format": "file",
      "title": "Audio",
      "type": "string"
    },
    "voice": {
      "default": "george",
      "description": "Target voice for transformation.",
      "enum": [
        "adam",
        "alice",
        "aria",
        "bella",
        "bill",
        "brian",
        "callum",
        "charlie",
        "chris",
        "daniel",
        "eric",
        "george",
        "harry",
        "jessica",
        "laura",
        "liam",
        "lily",
        "matilda",
        "river",
        "roger",
        "sarah",
        "will"
      ],
      "title": "Voice",
      "type": "string"
    },
    "model": {
      "default": "eleven_multilingual_sts_v2",
      "description": "Model to use. multilingual supports 70+ languages.",
      "enum": [
        "eleven_multilingual_sts_v2",
        "eleven_english_sts_v2"
      ],
      "title": "Model",
      "type": "string"
    },
    "output_format": {
      "default": "mp3_44100_128",
      "description": "Audio output format.",
      "enum": [
        "mp3_44100_128",
        "mp3_44100_192",
        "pcm_16000",
        "pcm_22050",
        "pcm_24000",
        "pcm_44100"
      ],
      "title": "Output Format",
      "type": "string"
    }
  },
  "required": [
    "audio"
  ],
  "title": "AppInput",
  "type": "object"
}