{
  "$defs": {
    "Element": {
      "properties": {
        "id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Unique identifier for the element",
          "title": "Id"
        },
        "layer_type": {
          "description": "Element type: 'text' or 'image'",
          "title": "Layer Type",
          "type": "string"
        },
        "content_type": {
          "description": "Format such as 'Heading #1', 'Body #1', 'Image #1' (numbers #1-#5)",
          "title": "Content Type",
          "type": "string"
        },
        "content": {
          "description": "Text string or image URL. Empty string to ignore this element.",
          "title": "Content",
          "type": "string"
        }
      },
      "required": [
        "layer_type",
        "content_type",
        "content"
      ],
      "title": "Element",
      "type": "object"
    },
    "SmartImage": {
      "properties": {
        "input_image_url": {
          "description": "URL of the image to embed within the smart image",
          "title": "Input Image Url",
          "type": "string"
        },
        "scene": {
          "$ref": "#/$defs/SmartImageScene",
          "description": "Background operation configuration"
        }
      },
      "required": [
        "input_image_url",
        "scene"
      ],
      "title": "SmartImage",
      "type": "object"
    },
    "SmartImageScene": {
      "properties": {
        "operation": {
          "description": "Background operation: 'expand_image' or 'lifestyle_shot_by_text'",
          "title": "Operation",
          "type": "string"
        },
        "input": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Background prompt or hex color. Ignored when operation is 'expand_image'.",
          "title": "Input"
        }
      },
      "required": [
        "operation"
      ],
      "title": "SmartImageScene",
      "type": "object"
    }
  },
  "properties": {
    "template_id": {
      "description": "Template ID for generating ad scenes (e.g. '1061', '1062')",
      "title": "Template Id",
      "type": "string"
    },
    "brand_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Brand ID for branded templates. Required for template 1062, ignored for 1061.",
      "title": "Brand Id"
    },
    "smart_image": {
      "anyOf": [
        {
          "$ref": "#/$defs/SmartImage"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Smart image config for embedding objects/products with AI backgrounds"
    },
    "elements": {
      "anyOf": [
        {
          "items": {
            "$ref": "#/$defs/Element"
          },
          "type": "array"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "List of text and image elements to customize in the template",
      "title": "Elements"
    },
    "content_moderation": {
      "anyOf": [
        {
          "type": "boolean"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Enable content moderation on inputs and outputs",
      "title": "Content Moderation"
    }
  },
  "required": [
    "template_id"
  ],
  "title": "AppInput",
  "type": "object"
}