{
  "$defs": {
    "KeyPoint": {
      "properties": {
        "x": {
          "description": "X coordinate of the key point",
          "title": "X",
          "type": "number"
        },
        "y": {
          "description": "Y coordinate of the key point",
          "title": "Y",
          "type": "number"
        },
        "label": {
          "default": 1,
          "description": "Point label: 1 for foreground, 0 for background",
          "title": "Label",
          "type": "integer"
        }
      },
      "required": [
        "x",
        "y"
      ],
      "title": "KeyPoint",
      "type": "object"
    }
  },
  "properties": {
    "video_url": {
      "description": "URL of the input video (MP4, MOV, WebM, AVI, GIF). Max 5s, 750p max.",
      "title": "Video Url",
      "type": "string"
    },
    "key_points": {
      "description": "List of coordinate key points to define the mask region",
      "items": {
        "$ref": "#/$defs/KeyPoint"
      },
      "title": "Key Points",
      "type": "array"
    },
    "output_container_and_codec": {
      "anyOf": [
        {
          "enum": [
            "mp4_h264",
            "mp4_h265",
            "webm_vp9",
            "mov_h265",
            "mov_proresks",
            "mkv_h264",
            "mkv_h265",
            "mkv_vp9",
            "gif"
          ],
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Output format preset (default: mp4_h264)",
      "title": "Output Container And Codec"
    }
  },
  "required": [
    "video_url",
    "key_points"
  ],
  "title": "AppInput",
  "type": "object"
}