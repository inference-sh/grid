{
  "$defs": {
    "AspectRatioEnum": {
      "enum": [
        "16:9",
        "9:16",
        "1:1",
        "4:3",
        "3:4",
        "3:2",
        "2:3",
        "21:9"
      ],
      "title": "AspectRatioEnum",
      "type": "string"
    },
    "ReferenceTypeEnum": {
      "enum": [
        "subject",
        "face"
      ],
      "title": "ReferenceTypeEnum",
      "type": "string"
    }
  },
  "description": "Kolors V1.5 - text-to-image with subject/face reference.\n\n- subject: preserves character features (body, clothing style)\n- face: preserves facial appearance only (single face required)",
  "properties": {
    "prompt": {
      "description": "Text description. Max 2500 chars.",
      "title": "Prompt",
      "type": "string"
    },
    "image": {
      "anyOf": [
        {
          "format": "file",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Reference image for subject/face consistency.",
      "title": "Image"
    },
    "image_reference": {
      "anyOf": [
        {
          "$ref": "#/$defs/ReferenceTypeEnum"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Reference type: 'subject' for character features, 'face' for facial appearance."
    },
    "image_fidelity": {
      "default": 0.5,
      "description": "Reference strength [0-1].",
      "maximum": 1.0,
      "minimum": 0.0,
      "title": "Image Fidelity",
      "type": "number"
    },
    "human_fidelity": {
      "default": 0.45,
      "description": "Facial similarity [0-1]. Only for 'subject' type.",
      "maximum": 1.0,
      "minimum": 0.0,
      "title": "Human Fidelity",
      "type": "number"
    },
    "negative_prompt": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "What to avoid. Not supported with image reference.",
      "title": "Negative Prompt"
    },
    "aspect_ratio": {
      "$ref": "#/$defs/AspectRatioEnum",
      "default": "16:9",
      "description": "Output aspect ratio."
    },
    "n": {
      "default": 1,
      "description": "Number of images (1-9).",
      "maximum": 9,
      "minimum": 1,
      "title": "N",
      "type": "integer"
    }
  },
  "required": [
    "prompt"
  ],
  "title": "AppInput",
  "type": "object"
}