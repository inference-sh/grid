{
  "$defs": {
    "AspectRatioEnum": {
      "enum": [
        "16:9",
        "9:16",
        "1:1",
        "4:3",
        "3:4",
        "3:2",
        "2:3"
      ],
      "title": "AspectRatioEnum",
      "type": "string"
    }
  },
  "description": "Kolors V1.0 - basic text-to-image and image-to-image.",
  "properties": {
    "prompt": {
      "description": "Text description. Max 2500 chars.",
      "title": "Prompt",
      "type": "string"
    },
    "image": {
      "anyOf": [
        {
          "format": "file",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Reference image for image-to-image (entire image style transfer).",
      "title": "Image"
    },
    "negative_prompt": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "What to avoid.",
      "title": "Negative Prompt"
    },
    "aspect_ratio": {
      "$ref": "#/$defs/AspectRatioEnum",
      "default": "16:9",
      "description": "Output aspect ratio."
    },
    "n": {
      "default": 1,
      "description": "Number of images (1-9).",
      "maximum": 9,
      "minimum": 1,
      "title": "N",
      "type": "integer"
    }
  },
  "required": [
    "prompt"
  ],
  "title": "AppInput",
  "type": "object"
}