  "$defs": {
    "ModeEnum": {
      "description": "Lip-sync mode \u2014 audio drives from an audio file, text uses TTS.",
      "enum": [
        "audio",
        "text"
      ],
      "title": "ModeEnum",
      "type": "string"
    },
    "VoiceIdEnum": {
      "description": "Available voice IDs for text-to-video mode.",
      "enum": [
        "genshin_vindi2",
        "zhinen_xuesheng",
