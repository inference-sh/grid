      "type": "string"
    },
    "VoiceLanguageEnum": {
      "description": "Language for TTS voice.",
      "enum": [
        "zh",
        "en"
      ],
      "title": "VoiceLanguageEnum",
      "type": "string"
    }
  },
  "description": "Input schema for Kling Lip-Sync.",
  "properties": {
    "video": {
      "description": "Source video to lip-sync. The model will modify lip movements to match the audio or text.",
      "format": "file",
      "title": "Video",
      "type": "string"
    },
    "mode": {
      "$ref": "#/$defs/ModeEnum",
      "default": "audio",
      "description": "Lip-sync mode. Audio mode uses an audio file to drive lip movements, text mode uses TTS."
    },
    "audio": {
      "anyOf": [
        {
          "format": "file",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Driving audio file for audio mode. Must be 2-120 seconds long.",
      "title": "Audio"
    },
    "text": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Text input for text mode. Maximum 120 characters.",
      "title": "Text"
    },
    "voice_id": {
      "anyOf": [
        {
          "$ref": "#/$defs/VoiceIdEnum"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Voice ID for text mode TTS. Required when mode is text."
    },
    "voice_language": {
      "anyOf": [
        {
          "$ref": "#/$defs/VoiceLanguageEnum"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Language for TTS voice (zh or en)."
    },
    "voice_speed": {
      "anyOf": [
        {
          "type": "number"
        },
        {
          "type": "null"
        }
      ],
      "default": 1.0,
      "description": "Speech rate for TTS voice. 1.0 is normal speed.",
      "title": "Voice Speed"
    }
  },
  "required": [
    "video"
  ],
  "title": "AppInput",
  "type": "object"
}