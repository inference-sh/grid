{
  "$defs": {
    "GeometryFormatEnum": {
      "description": "Output geometry file format options.",
      "enum": [
        "glb",
        "usdz",
        "fbx",
        "obj",
        "stl"
      ],
      "title": "GeometryFormatEnum",
      "type": "string"
    },
    "MaterialEnum": {
      "description": "Material type options.",
      "enum": [
        "PBR",
        "Shaded",
        "All"
      ],
      "title": "MaterialEnum",
      "type": "string"
    },
    "QualityMeshEnum": {
      "description": "Mesh quality and resolution options.",
      "enum": [
        "500K Triangle",
        "200K Triangle",
        "100K Triangle",
        "4K Quad",
        "2K Quad",
        "1K Quad"
      ],
      "title": "QualityMeshEnum",
      "type": "string"
    }
  },
  "properties": {
    "prompt": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Text guidance for 3D model generation (e.g., 'A futuristic robot with sleek metallic design')",
      "title": "Prompt"
    },
    "input_images": {
      "description": "Up to 5 reference images for 3D generation (at least one required)",
      "items": {
        "format": "file",
        "type": "string"
      },
      "minItems": 1,
      "title": "Input Images",
      "type": "array"
    },
    "geometry_file_format": {
      "$ref": "#/$defs/GeometryFormatEnum",
      "default": "glb",
      "description": "Output format for the 3D model geometry"
    },
    "material": {
      "$ref": "#/$defs/MaterialEnum",
      "default": "All",
      "description": "Material type for the 3D model"
    },
    "quality_mesh_option": {
      "$ref": "#/$defs/QualityMeshEnum",
      "default": "500K Triangle",
      "description": "Mesh resolution and type"
    },
    "use_original_alpha": {
      "default": false,
      "description": "Use original alpha channel from input images",
      "title": "Use Original Alpha",
      "type": "boolean"
    },
    "seed": {
      "anyOf": [
        {
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Random seed for reproducible generation",
      "title": "Seed"
    },
    "preview_render": {
      "default": false,
      "description": "Generate preview renders of the 3D model",
      "title": "Preview Render",
      "type": "boolean"
    }
  },
  "required": [
    "input_images"
  ],
  "title": "AppInput",
  "type": "object"
}