{
  "description": "Input schema for Kokoro TTS.",
  "properties": {
    "prompt": {
      "description": "Text to convert to speech.",
      "title": "Prompt",
      "type": "string"
    },
    "language": {
      "default": "american-english",
      "description": "Language for speech generation.",
      "enum": [
        "american-english",
        "british-english",
        "french",
        "spanish",
        "japanese",
        "italian",
        "hindi",
        "brazilian-portuguese",
        "mandarin-chinese"
      ],
      "title": "Language",
      "type": "string"
    },
    "voice": {
      "default": "af_heart",
      "description": "Voice ID for the desired voice.",
      "enum": [
        "af_heart",
        "af_alloy",
        "af_aoede",
        "af_bella",
        "af_jessica",
        "af_kore",
        "af_nicole",
        "af_nova",
        "af_river",
        "af_sarah",
        "af_sky",
        "am_adam",
        "am_echo",
        "am_eric",
        "am_fenrir",
        "am_liam",
        "am_michael",
        "am_onyx",
        "am_puck",
        "am_santa"
      ],
      "title": "Voice",
      "type": "string"
    },
    "speed": {
      "default": 1.0,
      "description": "Speed of the generated audio. Default is 1.0.",
      "maximum": 5.0,
      "minimum": 0.1,
      "title": "Speed",
      "type": "number"
    }
  },
  "required": [
    "prompt"
  ],
  "title": "AppInput",
  "type": "object"
}