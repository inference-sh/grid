{
  "$defs": {
    "VoiceIdEnum": {
      "description": "Voice options for text-to-speech.",
      "enum": [
        "Emily",
        "James",
        "Isabella",
        "Liam",
        "Chloe",
        "Adrian",
        "Harper",
        "Ava",
        "Sophia",
        "Julia",
        "Mason",
        "Jack",
        "Oliver",
        "Ethan",
        "Auto"
      ],
      "title": "VoiceIdEnum",
      "type": "string"
    }
  },
  "properties": {
    "video": {
      "description": "Input video file for lip synchronization. Supported formats: MP4, MOV, AVI",
      "format": "file",
      "title": "Video",
      "type": "string"
    },
    "audio": {
      "anyOf": [
        {
          "format": "file",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Audio file for lip sync. If not provided, TTS will be used with the text parameter. Supported formats: WAV, MP3",
      "title": "Audio"
    },
    "voice_id": {
      "$ref": "#/$defs/VoiceIdEnum",
      "default": "Auto",
      "description": "Voice to use for TTS when audio is not provided."
    },
    "text": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Text content for TTS when audio is not provided. Required if no audio file is given.",
      "title": "Text"
    }
  },
  "required": [
    "video"
  ],
  "title": "AppInput",
  "type": "object"
}