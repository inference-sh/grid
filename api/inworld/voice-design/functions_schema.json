        "VoicePreview": {
          "description": "A single voice preview.",
          "properties": {
            "output_meta": {
              "anyOf": [
                {
                  "$ref": "#/$defs/OutputMeta"
                },
                {
                  "type": "null"
                }
              ],
              "default": null,
              "description": "Structured metadata about inputs/outputs for pricing calculation"
            },
            "voice_id": {
              "description": "Temporary voice ID for this preview \u2014 use with the publish function to save it",
              "title": "Voice Id",
