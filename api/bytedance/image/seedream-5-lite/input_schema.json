{
  "$defs": {
    "AspectRatioEnum": {
      "description": "Aspect ratio options.",
      "enum": [
        "1:1",
        "3:4",
        "4:3",
        "16:9",
        "9:16",
        "3:2",
        "2:3",
        "21:9"
      ],
      "title": "AspectRatioEnum",
      "type": "string"
    },
    "OutputFormatEnum": {
      "description": "Output image format.",
      "enum": [
        "png",
        "jpeg"
      ],
      "title": "OutputFormatEnum",
      "type": "string"
    },
    "SizeEnum": {
      "description": "Image size/resolution options.",
      "enum": [
        "2K",
        "3K"
      ],
      "title": "SizeEnum",
      "type": "string"
    }
  },
  "description": "Input schema for Seedream 5 Lite image generation.",
  "properties": {
    "prompt": {
      "description": "Text prompt describing the image to generate. Be descriptive about style, composition, and details.",
      "examples": [
        "Vibrant close-up editorial portrait, model with piercing gaze, wearing a sculptural hat, rich color blocking"
      ],
      "title": "Prompt",
      "type": "string"
    },
    "images": {
      "anyOf": [
        {
          "items": {
            "format": "file",
            "type": "string"
          },
          "type": "array"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Optional reference images for image-to-image or multi-image blending. Up to 14 images supported.",
      "title": "Images"
    },
    "size": {
      "$ref": "#/$defs/SizeEnum",
      "default": "2K",
      "description": "Output image resolution. 2K or 3K."
    },
    "aspect_ratio": {
      "$ref": "#/$defs/AspectRatioEnum",
      "default": "1:1",
      "description": "Output image aspect ratio."
    },
    "output_format": {
      "$ref": "#/$defs/OutputFormatEnum",
      "default": "png",
      "description": "Output image format (png or jpeg)."
    },
    "watermark": {
      "default": false,
      "description": "Whether to add a watermark to the generated image.",
      "title": "Watermark",
      "type": "boolean"
    }
  },
  "required": [
    "prompt"
  ],
  "title": "AppInput",
  "type": "object"
}