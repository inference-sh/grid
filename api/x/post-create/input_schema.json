{
  "description": "Input schema for creating a post.",
  "properties": {
    "text": {
      "description": "Post text (max 280 characters)",
      "maxLength": 280,
      "minLength": 1,
      "title": "Text",
      "type": "string"
    },
    "reply_to_tweet_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Tweet ID to reply to (optional)",
      "title": "Reply To Tweet Id"
    },
    "quote_tweet_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Tweet ID to quote (optional)",
      "title": "Quote Tweet Id"
    },
    "media": {
      "anyOf": [
        {
          "items": {
            "format": "file",
            "type": "string"
          },
          "type": "array"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Media files to attach (up to 4 images, or 1 video/GIF). Supports JPG, PNG, GIF, WEBP, MP4.",
      "title": "Media"
    }
  },
  "required": [
    "text"
  ],
  "title": "AppInput",
  "type": "object"
}