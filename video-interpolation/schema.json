{
  "input": {
    "$defs": {
      "File": {
        "description": "A class representing a file in the inference.sh ecosystem.",
        "properties": {
          "uri": {
            "title": "Uri",
            "type": "string"
          },
          "path": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "Path"
          },
          "content_type": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "Content Type"
          },
          "size": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "Size"
          },
          "filename": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "Filename"
          }
        },
        "required": [
          "uri"
        ],
        "title": "File",
        "type": "object"
      }
    },
    "description": "Input for the RIFE video interpolation app.",
    "properties": {
      "video": {
        "$ref": "#/$defs/File",
        "description": "Input video file to be processed for frame interpolation"
      },
      "exp": {
        "default": 1,
        "description": "Interpolation factor: 2^exp frames will be generated between each original frame",
        "maximum": 4,
        "minimum": 0,
        "title": "Exp",
        "type": "integer"
      },
      "scale": {
        "default": 1.0,
        "description": "Scale factor for processing. Lower values (0.5, 0.25) recommended for 4K videos",
        "enum": [
          0.25,
          0.5,
          1.0,
          2.0,
          4.0
        ],
        "title": "Scale",
        "type": "number"
      },
      "fps": {
        "default": null,
        "description": "Target FPS. If None, will use source_fps * 2^exp",
        "title": "Fps",
        "type": "integer"
      },
      "keep_audio": {
        "default": true,
        "description": "Whether to transfer audio from source to output video",
        "title": "Keep Audio",
        "type": "boolean"
      }
    },
    "required": [
      "video"
    ],
    "title": "AppInput",
    "type": "object"
  },
  "output": {
    "$defs": {
      "File": {
        "description": "A class representing a file in the inference.sh ecosystem.",
        "properties": {
          "uri": {
            "title": "Uri",
            "type": "string"
          },
          "path": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "Path"
          },
          "content_type": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "Content Type"
          },
          "size": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "Size"
          },
          "filename": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "Filename"
          }
        },
        "required": [
          "uri"
        ],
        "title": "File",
        "type": "object"
      }
    },
    "description": "Output for the RIFE video interpolation app.",
    "properties": {
      "interpolated_video": {
        "$ref": "#/$defs/File"
      }
    },
    "required": [
      "interpolated_video"
    ],
    "title": "AppOutput",
    "type": "object"
  }
}