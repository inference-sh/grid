{
  "input": {
    "$defs": {
      "ConditioningImage": {
        "properties": {
          "image": {
            "$ref": "#/$defs/File"
          },
          "frame_index": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "Frame Index"
          },
          "strength": {
            "default": 1.0,
            "title": "Strength",
            "type": "number"
          }
        },
        "required": [
          "image"
        ],
        "title": "ConditioningImage",
        "type": "object"
      },
      "File": {
        "description": "A class representing a file in the inference.sh ecosystem.",
        "properties": {
          "uri": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "Uri"
          },
          "path": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "Path"
          },
          "content_type": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "Content Type"
          },
          "size": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "Size"
          },
          "filename": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "Filename"
          }
        },
        "title": "File",
        "type": "object"
      }
    },
    "properties": {
      "prompt": {
        "description": "Text prompt to guide video generation",
        "title": "Prompt",
        "type": "string"
      },
      "negative_prompt": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "null"
          }
        ],
        "default": "worst quality, inconsistent motion, blurry, jittery, distorted",
        "description": "Negative prompt to specify undesired features",
        "title": "Negative Prompt"
      },
      "width": {
        "anyOf": [
          {
            "type": "integer"
          },
          {
            "type": "null"
          }
        ],
        "default": 704,
        "description": "Width of the output video frames",
        "title": "Width"
      },
      "height": {
        "anyOf": [
          {
            "type": "integer"
          },
          {
            "type": "null"
          }
        ],
        "default": 480,
        "description": "Height of the output video frames",
        "title": "Height"
      },
      "num_frames": {
        "anyOf": [
          {
            "type": "integer"
          },
          {
            "type": "null"
          }
        ],
        "default": 121,
        "description": "Number of frames to generate in the output video",
        "title": "Num Frames"
      },
      "frame_rate": {
        "anyOf": [
          {
            "type": "integer"
          },
          {
            "type": "null"
          }
        ],
        "default": 25,
        "description": "Frame rate for the output video",
        "title": "Frame Rate"
      },
      "num_inference_steps": {
        "anyOf": [
          {
            "type": "integer"
          },
          {
            "type": "null"
          }
        ],
        "default": 8,
        "description": "Number of denoising steps in the diffusion process",
        "title": "Num Inference Steps"
      },
      "guidance_scale": {
        "anyOf": [
          {
            "type": "number"
          },
          {
            "type": "null"
          }
        ],
        "default": 3.0,
        "description": "Scale for classifier-free guidance",
        "title": "Guidance Scale"
      },
      "seed": {
        "anyOf": [
          {
            "type": "integer"
          },
          {
            "type": "null"
          }
        ],
        "default": 171198,
        "description": "Random seed for reproducibility",
        "title": "Seed"
      },
      "conditioning_images": {
        "anyOf": [
          {
            "items": {
              "$ref": "#/$defs/ConditioningImage"
            },
            "type": "array"
          },
          {
            "type": "null"
          }
        ],
        "default": null,
        "description": "List of conditioning images with their parameters",
        "title": "Conditioning Images"
      },
      "offload_to_cpu": {
        "anyOf": [
          {
            "type": "boolean"
          },
          {
            "type": "null"
          }
        ],
        "default": false,
        "description": "Whether to offload unnecessary computations to CPU",
        "title": "Offload To Cpu"
      },
      "image_cond_noise_scale": {
        "anyOf": [
          {
            "type": "number"
          },
          {
            "type": "null"
          }
        ],
        "default": 0.15,
        "description": "Scale of noise to add to conditioning images",
        "title": "Image Cond Noise Scale"
      },
      "input_media": {
        "anyOf": [
          {
            "$ref": "#/$defs/File"
          },
          {
            "type": "null"
          }
        ],
        "default": null,
        "description": "Input video file for video-to-video generation"
      },
      "strength": {
        "anyOf": [
          {
            "type": "number"
          },
          {
            "type": "null"
          }
        ],
        "default": 1.0,
        "description": "Strength of input video influence in video-to-video generation",
        "title": "Strength"
      },
      "pipeline_config": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "null"
          }
        ],
        "default": "configs/ltxv-2b-0.9.6-dev.yaml",
        "description": "Path to custom pipeline configuration file",
        "title": "Pipeline Config"
      }
    },
    "required": [
      "prompt"
    ],
    "title": "AppInput",
    "type": "object"
  },
  "output": {
    "$defs": {
      "File": {
        "description": "A class representing a file in the inference.sh ecosystem.",
        "properties": {
          "uri": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "Uri"
          },
          "path": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "Path"
          },
          "content_type": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "Content Type"
          },
          "size": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "Size"
          },
          "filename": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "Filename"
          }
        },
        "title": "File",
        "type": "object"
      }
    },
    "properties": {
      "video": {
        "$ref": "#/$defs/File"
      }
    },
    "required": [
      "video"
    ],
    "title": "AppOutput",
    "type": "object"
  }
}