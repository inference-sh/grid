{
  "input": {
    "properties": {
      "video_path": {
        "$ref": "#/$defs/File",
        "description": "Input video file for lip syncing",
        "title": "Video Path"
      },
      "audio_path": {
        "$ref": "#/$defs/File",
        "description": "Input audio file to sync with the video",
        "title": "Audio Path"
      },
      "inference_steps": {
        "default": 20,
        "description": "Number of inference steps for the lip sync model",
        "minimum": 1,
        "title": "Inference Steps",
        "type": "integer"
      },
      "guidance_scale": {
        "default": 1.5,
        "description": "Guidance scale for the lip sync model",
        "minimum": 0.0,
        "title": "Guidance Scale",
        "type": "number"
      }
    },
    "required": [
      "video_path",
      "audio_path"
    ],
    "title": "AppInput",
    "type": "object",
    "$defs": {
      "File": {
        "description": "A class representing a file in the inference.sh ecosystem.",
        "properties": {
          "path": {
            "title": "Path",
            "type": "string"
          },
          "mime_type": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "Mime Type"
          },
          "size": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "Size"
          },
          "filename": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "Filename"
          }
        },
        "required": [
          "path"
        ],
        "title": "File",
        "type": "object"
      }
    }
  },
  "output": {
    "properties": {
      "result_video": {
        "$ref": "#/$defs/File",
        "description": "The output video with synchronized lips"
      }
    },
    "required": [
      "result_video"
    ],
    "title": "AppOutput",
    "type": "object",
    "$defs": {
      "File": {
        "description": "A class representing a file in the inference.sh ecosystem.",
        "properties": {
          "path": {
            "title": "Path",
            "type": "string"
          },
          "mime_type": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "Mime Type"
          },
          "size": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "Size"
          },
          "filename": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "Filename"
          }
        },
        "required": [
          "path"
        ],
        "title": "File",
        "type": "object"
      }
    }
  }
}