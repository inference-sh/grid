{
  "input": {
    "$defs": {
      "Mode": {
        "enum": [
          "t2v",
          "i2v",
          "v2v"
        ],
        "title": "Mode",
        "type": "string"
      }
    },
    "properties": {
      "mode": {
        "$ref": "#/$defs/Mode",
        "description": "The mode of the pipeline"
      },
      "prompt": {
        "description": "The prompt for the pipeline. Used for all modes.",
        "title": "Prompt",
        "type": "string"
      },
      "image_path": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "null"
          }
        ],
        "default": null,
        "description": "For i2v mode, the source image path",
        "title": "Image Path"
      },
      "prefix_video_path": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "null"
          }
        ],
        "default": null,
        "description": "For v2v mode, the source video path",
        "title": "Prefix Video Path"
      }
    },
    "required": [
      "mode",
      "prompt"
    ],
    "title": "AppInput",
    "type": "object"
  },
  "output": {
    "$defs": {
      "File": {
        "description": "A class representing a file in the inference.sh ecosystem.",
        "properties": {
          "uri": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "Uri"
          },
          "path": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "Path"
          },
          "content_type": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "Content Type"
          },
          "size": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "Size"
          },
          "filename": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "Filename"
          }
        },
        "title": "File",
        "type": "object"
      }
    },
    "properties": {
      "video": {
        "$ref": "#/$defs/File"
      }
    },
    "required": [
      "video"
    ],
    "title": "AppOutput",
    "type": "object"
  }
}