            "seconds": {
              "default": 0,
              "description": "Duration in seconds",
              "title": "Seconds",
              "type": "number"
            },
            "fps": {
              "default": 0,
              "description": "Frames per second",
              "title": "Fps",
              "type": "integer"
            }
