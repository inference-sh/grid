{
  "bar_chart": {
    "description": "",
    "input_schema": {
      "description": "Simple bar chart \u2014 horizontal or vertical.",
      "properties": {
        "title": {
          "description": "Chart title",
          "title": "Title",
          "type": "string"
        },
        "labels": {
          "description": "Category labels",
          "items": {
            "type": "string"
          },
          "title": "Labels",
          "type": "array"
        },
        "values": {
          "description": "Values for each bar",
          "items": {
            "type": "number"
          },
          "title": "Values",
          "type": "array"
        },
        "colors": {
          "anyOf": [
            {
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Bar colors (hex or named)",
          "title": "Colors"
        },
        "xlabel": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "X-axis label",
          "title": "Xlabel"
        },
        "ylabel": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Y-axis label",
          "title": "Ylabel"
        },
        "horizontal": {
          "default": false,
          "description": "Horizontal bars",
          "title": "Horizontal",
          "type": "boolean"
        },
        "value_labels": {
          "default": true,
          "description": "Show value on each bar",
          "title": "Value Labels",
          "type": "boolean"
        },
        "width": {
          "default": 800,
          "description": "Image width in pixels",
          "title": "Width",
          "type": "integer"
        },
        "height": {
          "default": 500,
          "description": "Image height in pixels",
          "title": "Height",
          "type": "integer"
        },
        "highlight_max": {
          "default": true,
          "description": "Bold the highest bar",
          "title": "Highlight Max",
          "type": "boolean"
        }
      },
      "required": [
        "title",
        "labels",
        "values"
      ],
      "title": "BarChartInput",
      "type": "object"
    },
    "output_schema": {
      "$defs": {
        "AudioMeta": {
          "description": "Metadata for audio inputs/outputs.",
          "properties": {
            "type": {
              "default": "audio",
              "title": "Type",
              "type": "string"
            },
            "extra": {
              "anyOf": [
                {
                  "additionalProperties": true,
                  "type": "object"
                },
                {
                  "type": "null"
                }
              ],
              "default": null,
              "description": "App-specific key-value pairs for custom pricing factors",
              "title": "Extra"
            },
            "seconds": {
              "default": 0,
              "description": "Duration in seconds",
              "title": "Seconds",
              "type": "number"
            },
            "sample_rate": {
              "default": 0,
              "description": "Sample rate in Hz",
              "title": "Sample Rate",
              "type": "integer"
