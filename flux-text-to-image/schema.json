{
  "input": {
    "description": "Input parameters for generating images from text descriptions",
    "examples": [
      {
        "guidance_scale": 4.0,
        "height": 1024,
        "number_of_images": 1,
        "number_of_steps": 28,
        "prompt": "a photo of a cat sitting on a windowsill at sunset",
        "seed": 42,
        "width": 1024
      }
    ],
    "properties": {
      "prompt": {
        "description": "The text prompt describing the desired image",
        "examples": [
          "a photo of a cat sitting on a windowsill at sunset",
          "an oil painting of mountains at sunrise"
        ],
        "maxLength": 1000,
        "minLength": 1,
        "title": "Prompt",
        "type": "string"
      },
      "number_of_images": {
        "default": 1,
        "description": "Number of images to generate",
        "examples": [
          1,
          2
        ],
        "maximum": 4,
        "minimum": 1,
        "title": "Number Of Images",
        "type": "integer"
      },
      "width": {
        "default": 1024,
        "description": "Width of generated image in pixels",
        "examples": [
          1024,
          768
        ],
        "maximum": 2048,
        "minimum": 512,
        "title": "Width",
        "type": "integer"
      },
      "height": {
        "default": 1024,
        "description": "Height of generated image in pixels",
        "examples": [
          1024,
          768
        ],
        "maximum": 2048,
        "minimum": 512,
        "title": "Height",
        "type": "integer"
      },
      "number_of_steps": {
        "default": 28,
        "description": "Number of denoising steps (higher = better quality but slower)",
        "examples": [
          28,
          50
        ],
        "maximum": 100,
        "minimum": 1,
        "title": "Number Of Steps",
        "type": "integer"
      },
      "guidance_scale": {
        "default": 4.0,
        "description": "How closely to follow the prompt (higher = more faithful but less creative)",
        "examples": [
          4.0,
          7.5
        ],
        "maximum": 20.0,
        "minimum": 1.0,
        "title": "Guidance Scale",
        "type": "number"
      },
      "seed": {
        "default": 0,
        "description": "Random seed for reproducible results",
        "examples": [
          42,
          123456
        ],
        "minimum": 0,
        "title": "Seed",
        "type": "integer"
      }
    },
    "required": [
      "prompt"
    ],
    "title": "Text to Image Generation Input",
    "type": "object"
  },
  "output": {
    "$defs": {
      "File": {
        "description": "A class representing a file in the inference.sh ecosystem.",
        "properties": {
          "path": {
            "title": "Path",
            "type": "string"
          },
          "mime_type": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "Mime Type"
          },
          "size": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "Size"
          },
          "filename": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "Filename"
          }
        },
        "required": [
          "path"
        ],
        "title": "File",
        "type": "object"
      }
    },
    "properties": {
      "result": {
        "description": "List of generated image files",
        "items": {
          "$ref": "#/$defs/File"
        },
        "minItems": 1,
        "title": "Result",
        "type": "array"
      }
    },
    "required": [
      "result"
    ],
    "title": "AppOutput",
    "type": "object"
  }
}